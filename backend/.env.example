# Copy this file to `.env` and fill in your own credentials.
# Never commit the real `.env`.

# Pinata (IPFS pinning)
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# Ganache / local chain
GANACHE_URL=http://127.0.0.1:7545

# Optional fallback sender for POST /upload.
# Use one unlocked Ganache account address. Leave empty if you prefer sending
# owner_address in each multipart request.
DEFAULT_OWNER_ADDRESS=

# Optional: if you switch to JWT-based auth later
# PINATA_JWT=
